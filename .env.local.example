# Supabase — get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used only in server-side API routes
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Twilio — SMS notifications (server-side only, never prefix with NEXT_PUBLIC_)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
BARBER_SMS_NUMBER=+1234567890
